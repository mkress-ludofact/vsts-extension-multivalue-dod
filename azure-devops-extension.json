{
    "manifestVersion": 1.0,
    "id": "vsts-extensions-multivalue-control-dod",
    "version": "2.2.29",
    "name": "Multivalue control - DoD",
    "description": "A work item form control for Definition of Done checklists. Shows all items and requires all to be checked before moving to Done.",
    "publisher": "mk-lf",
    "icons": {
        "default": "img/logo.png"
    },
    "categories": [
        "Azure Boards"
    ],
    "targets": [
        {
            "id": "Microsoft.VisualStudio.Services"
        }
    ],
    "files": [
        {
            "path": "dist",
            "addressable": true
        },
        {
            "path": "img",
            "addressable": true
        }
    ],
    "repository": {
        "type": "git",
        "uri": "https://github.com/mkress-ludofact/vsts-extension-multivalue-dod"
    },
    "links": {
        "repository": {
            "uri": "https://github.com/mkress-ludofact/vsts-extension-multivalue-dod"
        },
        "issues": {
            "uri": "https://github.com/mkress-ludofact/vsts-extension-multivalue-dod/issues"
        },
        "support": {
            "uri": "https://github.com/mkress-ludofact/vsts-extension-multivalue-dod/issues"
        }
    },
    "tags": [
        "Work Items",
        "Extensions",
        "Work Item Control",
        "Sample",
        "Multivalue Control"
    ],
    "content": {
        "details": {
            "path": "marketplace/overview.md"
        },
        "license": {
            "path": "LICENSE"
        }
    },
    "scopes": [
        "vso.work"
    ],
    "contributions": [
        {
            "id": "multivalue-form-control-dod",
            "type": "ms.vss-work-web.work-item-form-control",
            "description": "A Definition of Done checklist control. All items must be checked before transitioning to Done.",
            "targets": [
                "ms.vss-work-web.work-item-form"
            ],
            "properties": {
                "name": "Multivalue control - DoD",
                "uri": "dist/multivalue.html",
                "height": 120,
                "inputs": [
                    {
                        "id": "FieldName",
                        "name": "Select the field for this control. This is the only input needed if the field is a picklist field with suggested values.",
                        "type": "WorkItemField",
                        "properties": {
                            "workItemFieldTypes": [
                                "String",
                                "PlainText",
                                "HTML"
                            ]
                        },
                        "validation": {
                            "dataType": "String",
                            "isRequired": true
                        }
                    },
                    {
                        "id": "Values",
                        "name": "Choose values for the control. This is only required if you're not using a picklist field. Example: Windows; IOS; Linux",
                        "description": "Values can be user provided or from suggested values of the backing field",
                        "validation": {
                            "dataType": "String",
                            "isRequired": false
                        }
                    },
                    {
                        "id": "AllowCustom",
                        "name": "Allow users to enter custom values",
                        "inputMode": "CheckBox",
                        "validation": {
                            "dataType": "Boolean",
                            "isRequired": false
                        }
                    },
                    {
                        "id": "LabelDisplayLength",
                        "name": "Set the maximum display length for each option's label. Defaults to 35 if not set.",
                        "validation": {
                            "dataType": "Number",
                            "isRequired": false
                        }
                    }
                ]
            }
        }
    ]
}